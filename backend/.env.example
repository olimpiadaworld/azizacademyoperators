# Local development uchun
# Production/Railway uchun Variables bo'limiga shu nomlar bilan kiriting.

NODE_ENV=development
DEBUG=True
SECRET_KEY=change-this-local-django-secret
HOST=127.0.0.1
PORT=8000
TIME_ZONE=Asia/Tashkent

# Local PostgreSQL:
DATABASE_URL=postgresql://postgres:YOUR_LOCAL_POSTGRES_PASSWORD@localhost:5432/azizacademyoperators
DB_SSL_REQUIRE=false

# Local frontend originlari
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_HOSTS=127.0.0.1,localhost

JWT_ACCESS_SECRET=change-this-to-long-random-access-secret-local
JWT_REFRESH_SECRET=change-this-to-different-long-random-refresh-secret-local
ACCESS_TOKEN_EXPIRES_IN=30m
REFRESH_TOKEN_EXPIRES_IN=7d

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_TO_STRONG_ADMIN_PASSWORD
ADMIN_FULL_NAME=Administrator
ADMIN_PHONE=

API_RATE_LIMIT_PER_MINUTE=240
AUTH_RATE_LIMIT_PER_15_MINUTES=20
PUBLIC_LEAD_RATE_LIMIT_PER_MINUTE=8
MAX_UPLOAD_MB=10

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CHAT_IDS=
