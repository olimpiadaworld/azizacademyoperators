# Railway backend Variables uchun tayyor variant
# Postgres service nomi Railway'da "Postgres" bo'lsa DATABASE_URL shu holatda qoladi.
# Agar service nomi boshqacha bo'lsa: ${{SERVICE_NOMI.DATABASE_URL}}

NODE_ENV=production
DEBUG=False
SECRET_KEY=CHANGE_TO_64_PLUS_RANDOM_DJANGO_SECRET
HOST=0.0.0.0
TIME_ZONE=Asia/Tashkent

DATABASE_URL=${{Postgres.DATABASE_URL}}
DB_SSL_REQUIRE=true

ALLOWED_HOSTS=.up.railway.app
CORS_ALLOWED_ORIGINS=https://azizacademyoperators.netlify.app
CSRF_TRUSTED_ORIGINS=https://azizacademyoperators.netlify.app

JWT_ACCESS_SECRET=CHANGE_TO_64_PLUS_RANDOM_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_TO_DIFFERENT_64_PLUS_RANDOM_REFRESH_SECRET
ACCESS_TOKEN_EXPIRES_IN=30m
REFRESH_TOKEN_EXPIRES_IN=7d

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_TO_STRONG_ADMIN_PASSWORD
ADMIN_FULL_NAME=Administrator
ADMIN_PHONE=

API_RATE_LIMIT_PER_MINUTE=240
AUTH_RATE_LIMIT_PER_15_MINUTES=20
PUBLIC_LEAD_RATE_LIMIT_PER_MINUTE=8
MAX_UPLOAD_MB=10

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CHAT_IDS=
